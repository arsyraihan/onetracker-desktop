{
  "name": "onetracker-desktop",
  "version": "2.2.2",
  "description": "OneTracker Desktop Application",
  "main": "index.js",
  "scripts": {
    "start": "electron .",
    "build:win": "electron-builder --win",
    "build:linux": "electron-builder --linux",
    "build:mac": "electron-builder --mac",
    "build:all": "electron-builder -wml"
  },
  "author": "NasPad Team",
  "license": "ISC",
  "build": {
    "appId": "com.naspad.onetracker",
    "productName": "OneTracker",
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "win": {
      "target": "nsis",
      "icon": "build/app-icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "installerIcon": "build/setup-icon.ico",
      "uninstallerIcon": "build/setup-icon.ico",
      "installerHeaderIcon": "build/setup-icon.ico"
    },
    "mac": {
      "target": "dmg",
      "icon": "build/app-icon.icns"
    },
    "linux": {
      "target": [
        "AppImage",
        "deb"
      ],
      "icon": "build/app-icon.png",
      "category": "Office"
    }
  }
}